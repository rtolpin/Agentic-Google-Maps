# ─────────────────────────────────────────────────────────────
#  The Right Spot — Environment Variables
#  Copy to .env and fill in your values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── AI / LLM ─────────────────────────────────────────────────
# Anthropic Claude — intent parsing, signal extraction, synthesis
# Get at: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Flight Search ─────────────────────────────────────────────
# Serpapi — Google Flights scraper for the in-app ✈️ Fly mode
# Get at: https://serpapi.com → Dashboard → API Key
SERPAPI_API_KEY=

# ── Data Scraping ─────────────────────────────────────────────
# Nimble SERP API — Google Maps + organic SERP extraction at scale
# Extracts Google Place IDs, addresses, coordinates, review snippets
# Get at: https://nimbleway.com → Dashboard → API Keys
NIMBLE_API_KEY=...

# ── AI Governance ─────────────────────────────────────────────
# Senso.ai — GEO (Generative Engine Optimization) & hallucination prevention
# System of record: knowledge base, governance scoring, content gaps
# Get at: https://app.senso.ai → Settings → API Keys
SENSO_API_KEY=...

# ── Maps ──────────────────────────────────────────────────────
# Google Maps Platform — real-time place details + JavaScript map rendering
# Required APIs to enable in Google Cloud Console:
#   • Maps JavaScript API       (frontend map rendering)
#   • Places API (New)          (real-time place details, find place)
#   • Geocoding API             (address → lat/lng)
# Billing: ~$5–$7 per 1,000 Places requests (use field masks — already set)
# Get at: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_MAPS_API_KEY=AIza...

# Google Maps Map ID — create at: https://console.cloud.google.com → Google Maps Platform → Map Management
# Required for AdvancedMarkerElement (the new pin API used in VenueMap.tsx)
GOOGLE_MAPS_MAP_ID=...

# ── Database ──────────────────────────────────────────────────
# ClickHouse — analytical DB for venue signals (runs in Docker)
# Default user is 'default' with no password in dev; set a password for prod
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=rightspot

# ── Cache ─────────────────────────────────────────────────────
# Redis — intent cache (1hr TTL), session memory, rate limiting
# Runs in Docker in dev; use Upstash or Redis Cloud for prod
REDIS_URL=redis://localhost:6379

# ── Observability ─────────────────────────────────────────────
# Datadog APM — distributed tracing for AI agent spans
# Required only for production; mock tracer is used in tests (no agent needed)
# Get at: https://app.datadoghq.com → Organization Settings → API Keys
DD_API_KEY=
DD_APP_KEY=
DD_SITE=datadoghq.com
DD_SERVICE=therightspot-api
DD_ENV=development
DD_VERSION=2.0.0

# ── Frontend (Next.js public vars) ────────────────────────────
# These are embedded in the browser bundle — no secrets here
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_GOOGLE_MAPS_KEY=${GOOGLE_MAPS_API_KEY}
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=${GOOGLE_MAPS_MAP_ID}
